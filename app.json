{
  "expo": {
    "name": "VoiceKeeper",
    "slug": "voicekeeper",
    "version": "1.0.0",
    "icon": "./assets/logo.png",
    "orientation": "portrait",
    "scheme": "voicekeeper",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voicekeeper.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoiceKeeper needs microphone access to record voice notes.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.voicekeeper.app",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ac0d3a9-c322-4305-b745-fc12b582b3ff"
      }
    }
  }
}
