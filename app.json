{
  "expo": {
    "name": "VoiceKeeper",
    "slug": "voicekeeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "voicekeeper",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voicekeeper.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoiceKeeper needs microphone access to record voice notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5"
      },
      "package": "com.voicekeeper.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
